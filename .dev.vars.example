# Local secrets for `wrangler dev` — copy to .dev.vars (gitignored).
# In production, set the same names via `wrangler secret put <NAME>`.
#
# The active deliverer (src/lib/server/contact.ts) chains Resend (primary)
# and Airtable (secondary). Set the env vars below to activate each
# channel. If either is missing, that channel falls back to no-op.

# === Resend → email (primary) ===
# Get RESEND_API_KEY from https://resend.com/api-keys after verifying
# your sending domain. Verify the apex by adding the DNS records Resend
# gives you in the Cloudflare dashboard (~5 min).
RESEND_API_KEY=
CONTACT_TO=platte@root.site
CONTACT_FROM=root. <hello@root.site>

# === Airtable → row (secondary, best-effort) ===
# AIRTABLE_TOKEN is a personal access token from
# https://airtable.com/create/tokens with data.records:write on the base.
# Table must have columns: Name, Email, Message, Received.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Contacts

# === Cloudflare Web Analytics beacon (optional) ===
# Paste the token from Cloudflare → Analytics → Web Analytics → Add a
# site → JS snippet. Without this, the beacon script is omitted.
PUBLIC_CF_ANALYTICS_TOKEN=
